---
export interface Props {
  images: string[];
}

const { images } = Astro.props;
---

<div id="indicators-carousel" class="relative w-full" data-carousel="static">
  <!-- Contenedor -->
  <div class="relative overflow-hidden rounded-lg border-white/10 border-2 h-33 md:h-76">
    {
      images.map((image, index) => (
        <div
          class={`duration-700 ease-in-out ${index === 0 ? "" : "hidden"}`}
          data-carousel-item
        >
          <img
            src={image}
            class="absolute block w-full -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2"
            alt={`Slide ${index + 1}`}
          />
        </div>
      ))
    }
  </div>

  <!-- Indicadores 
  <div class="absolute z-30 flex -translate-x-1/2 space-x-3 rtl:space-x-reverse bottom-5 left-1/2">
    {
      images.map((_, index) => (
        <button
          type="button"
          class="w-3 h-3 rounded-full"
          aria-current={index === 0 ? "true" : "false"}
          aria-label={`Slide ${index + 1}`}
          data-carousel-slide-to={index}
        />
      ))
    }
  </div>
  -->

  <!-- Anterior -->
  <button
    type="button"
    class="absolute top-0 start-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none"
    data-carousel-prev
  >
    <span
      class="inline-flex items-center justify-center size-6 lg:size-10 rounded-full bg-black/30 group-hover:bg-black/50"
    >
      <svg
        class="size-3 lg:size-4 text-white rtl:rotate-180"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 6 10"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5 1 1 5l4 4"
        ></path>
      </svg>
      <span class="sr-only">Previous</span>
    </span>
  </button>

  <!-- Siguiente -->
  <button
    type="button"
    class="absolute top-0 end-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none"
    data-carousel-next
  >
    <span
      class="inline-flex items-center justify-center size-6 lg:size-10 rounded-full bg-black/30 group-hover:bg-black/50"
    >
      <svg
        class="size-3 lg:size-4 text-white rtl:rotate-180"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 6 10"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="m1 9 4-4-4-4"
        ></path>
      </svg>
      <span class="sr-only">Next</span>
    </span>
  </button>
</div>
