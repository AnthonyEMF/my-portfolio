---
import { projects, otherProjects } from "../storage/projects";
import Carousel from "./ui/Carousel.astro";
---

<!-- Proyectos de programación -->
{
  projects.map(({ title, description, images, links, tags }) => (
    <article class="flex flex-col gap-x-4 gap-y-2 mb-8 bg-gray-500/30 border-white/10 border-2 p-3 lg:p-5 rounded-lg">

      {/* Información */}
      <h3 class="text-white text-2xl text-center font-semibold">{title}</h3>
      <p class="lg:text-center text-sm lg:text-base text-gray-300 mb-1">{description}</p>

      {/* Imagenes */}
      <Carousel images={images} />

      {/* Etiquetas */}
      <div class="flex gap-2 flex-wrap mt-2">
        {tags.map((tag) => (
          <span class={`${tag.class} text-white flex justify-center items-center rounded-md px-2 py-1 text-xs gap-1`}>
            <tag.icon class="size-4" /> {tag.name}
          </span>
        ))}
      </div>

      {/* Links del repositorio */}
      <span class="flex gap-2 flex-wrap">
        {links.map(({ name, href }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-cyan-400 text-xs lg:text-base hover:underline"
          >
           + {name}
          </a>
        ))}
      </span>

    </article>
  ))
}

<!-- Otros proyectos -->
<article class="flex flex-col gap-x-4 gap-y-2 mb-8 bg-gray-500/30 border-white/10 border-2 p-3 lg:p-5 rounded-lg">
  {/* Información */}
  <h3 class="text-white text-2xl text-center font-semibold">{otherProjects.title}</h3>
  <p class="lg:text-center text-sm lg:text-base text-gray-300 mb-1">
    {otherProjects.description}
  </p>

  {/* Links */}
  <span class="flex justify-evenly gap-2 flex-wrap">
    {
      otherProjects.links.map(({ name, href }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="border-white/10 hover:bg-white/10 hover:text-white text-white
          rounded-full border-2 flex justify-center items-center 
          gap-x-2 py-1 px-2 lg:py-2 lg:px-4 text-sm lg:text-base"
        >
         {name}
        </a>
      ))
    }
  </span>
  
</article>
