---
import Layout from "../layouts/Layout.astro";
import SectionContainer from "../components/ui/SectionContainer.astro";
import Badge from "../components/ui/Badge.astro";
import GitHub from "../icons/social/GitHub.astro";
import LinkedIn from "../icons/social/LinkedIn.astro";
import SocialPill from "../components/ui/SocialPill.astro";
import Instagram from "../icons/social/Instagram.astro";
import Gmail from "../icons/social/Gmail.astro";
import Timeline from "../components/Timeline.astro";
import Skills from "../components/Skills.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";
import SchoolIcon from "../icons/School.astro";
import CodeIcon from "../icons/Code.astro";
import AboutUserIcon from "../icons/AboutUser.astro";
import BladesIcon from "../icons/Blades.astro";
---

<Layout>
  <main class="px-4">

    <!-- Perfil -->
    <SectionContainer class="mt-30 lg:mt-40">
      <!-- Foto de perfil -->
      <img
        class="rounded-full size-24 mb-4"
        src="/images/profile-photo.webp"
        alt="profile photo"
      />
      <!-- Titulo -->
      <h1 class="text-white text-2xl md:text-4xl lg:text-5xl font-bold flex flex-col lg:flex-row gap-x-4 pb-2 lg:pb-4">
        Hola, soy Anthony 👋🏻
        <a 
          class="flex justify-start lg:justify-center items-center mt-2 lg:my-0"
          href="https://www.linkedin.com/in/anthony-miranda-8a140b362/"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Badge color="green">Disponible para trabajar</Badge>
        </a>
      </h1>
      <!-- Descripción breve -->
      <h2 class="text-xl lg:text-2xl opactiry-80 text-wrap max-w-[800px]">
        <span class="text-white">Ingeniero en Sistemas.</span>
        <span class="text-yellow-200/90">Desarrollador Web/Mobile FullStack.</span>
        <span class="text-red-200/90"> Entusiasta de la tecnología.</span>
        <span class="text-blue-200/90"> De Santa Rosa de Copán, Honduras.</span>
      </h2>
      <!-- Redes sociales -->
      <nav class="flex gap-2 lg:gap-x-4 my-4 flex-wrap">
        <SocialPill href="https://github.com/AnthonyEMF">
         <GitHub class="size-4 lg:size-6"/> GitHub
        </SocialPill>
        <SocialPill href="https://www.linkedin.com/in/anthony-miranda-8a140b362/">
          <LinkedIn class="size-4 lg:size-6"/> LinkedIn
        </SocialPill>
        <SocialPill href="https://www.instagram.com/anthony.emf/">
          <Instagram class="size-4 lg:size-6"/> Instagram
        </SocialPill>
        <SocialPill href="mailto:anthony07miranda@gmail.com">
          <Gmail class="size-4 lg:size-6"/> anthony07miranda@gmail.com
        </SocialPill>
      </nav>
    </SectionContainer>

    <!-- Sobre mi -->
    <SectionContainer id="about" class="pt-20">
      <h2 class="text-white text-2xl font-semibold flex justify-center items-center gap-x-2">
        <AboutUserIcon class="size-6 lg:size-7"/>
        Sobre mí
      </h2>
      <About/>
    </SectionContainer>

    <!-- Formación -->
    <SectionContainer id="timeline" class="pt-20">
      <h2 class="text-white text-2xl font-semibold mb-4 flex justify-center items-center gap-x-2">
        <SchoolIcon class="size-6 lg:size-7"/>
        Formación Académica
      </h2>
      <Timeline/>
    </SectionContainer>
    
    <!-- Habilidades -->
    <SectionContainer id="skills" class="pt-20">
      <h2 class="text-white text-2xl font-semibold mb-4 flex justify-center items-center gap-x-2">
        <BladesIcon class="size-6 lg:size-7"/>
        Habilidades
      </h2>
      <Skills/>
    </SectionContainer>

    <!-- Proyectos -->
    <SectionContainer id="projects" class="pt-20">
      <h2 class="text-white text-2xl font-semibold mb-4 flex justify-center items-center gap-x-2">
        <CodeIcon class="size-6 lg:size-7"/>
        Proyectos
      </h2>
      <Projects/>
    </SectionContainer>
    
  </main>
</Layout>
